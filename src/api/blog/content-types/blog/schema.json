{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "content": {
      "type": "customField",
      "customField": "plugin::react-quill-editor.react-quill"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "names"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "blogs"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "mappedBy": "blogs"
    },
    "media": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "media_alt": {
      "type": "text"
    },
    "page_metadata": {
      "type": "text"
    },
    "thumbnail_image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "thumbnail_alt": {
      "type": "text"
    },
    "video_url": {
      "type": "string"
    },
    "pre_roll_video": {
      "type": "string"
    },
    "subtext": {
      "type": "text"
    },
    "weight": {
      "type": "integer"
    },
    "sections": {
      "type": "component",
      "component": "vehicle.content-section",
      "repeatable": true
    }
  }
}
